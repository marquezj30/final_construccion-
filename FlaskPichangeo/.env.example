FLASK_ENV=development
SECRET_KEY=cambia-esta-clave-para-sesiones-flask

# Opcion Azure SQL Server: pega aqui el connection string de .NET.
# Requiere ODBC Driver 18 for SQL Server.
SQLSERVER_CONNECTION_STRING=Server=tcp:tu-servidor.database.windows.net,1433;Initial Catalog=tu-db;Persist Security Info=False;User ID=tu-usuario;Password=tu-password;MultipleActiveResultSets=False;Encrypt=True;TrustServerCertificate=False;Connection Timeout=30;
SQLSERVER_ODBC_DRIVER=ODBC Driver 18 for SQL Server

# Opcion local si quieres volver a SQLite:
# DATABASE_URL=sqlite:///pichangeo.db
JWT_SECRET_KEY=Pichangeo_Super_Secret_Key_Para_Tokens_2026_!@#$
JWT_ISSUER=BackPichangeoAPI
JWT_AUDIENCE=BackPichangeoClients
JWT_ACCESS_TOKEN_MINUTES=15
JWT_REFRESH_TOKEN_DAYS=7
AUTO_CREATE_DB=true
AUTO_SEED_ADMIN=true
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_NAME=Administrador
DEFAULT_ADMIN_EMAIL=admin@pichangeo.local
DEFAULT_ADMIN_PASSWORD=Admin123!

# OAuth 2.0 / OpenID Connect con Auth0.
# En Auth0 crea una aplicacion tipo "Regular Web Application".
# Allowed Callback URLs: http://127.0.0.1:5000/api/oauth/auth0/callback
AUTH0_DOMAIN=dev-0sypx3doiiavt4kx.us.auth0.com
AUTH0_CLIENT_ID=C4ncMVRvhQyj2pKqLiN1KMPCJgU0QkSi
AUTH0_CLIENT_SECRET=ztHvOJxf2mlg53KUw4Z8356TBHp9Vn8e9l_a7ScBgZ56QcZUphGX39LgG7dH3DaR
AUTH0_AUDIENCE=
AUTH0_SCOPE=openid profile email
AUTH0_CALLBACK_URL=http://127.0.0.1:5000/api/oauth/auth0/callback

# Origenes permitidos por CORS para el frontend Angular (separados por coma).
CORS_ORIGINS=http://localhost:4200
